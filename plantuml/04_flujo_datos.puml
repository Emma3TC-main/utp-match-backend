@startuml 04_flujo_datos_utp_match
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam handwritten false
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam ArrowColor #444444
skinparam classAttributeIconSize 0
skinparam roundcorner 12
skinparam nodesep 45
skinparam ranksep 40
title UTP Match - Diagrama de flujo de datos DFD nivel 1

actor "Estudiante" as Student
actor "Administrador" as Admin
actor "Familia/Tutor" as Family

rectangle "P1. Capturar perfil
y consentimiento" as P1
rectangle "P2. Registrar reporte
vocacional" as P2
rectangle "P3. Consultar catálogo
de carreras/cursos" as P3
rectangle "P4. Generar comparación
de carreras" as P4
rectangle "P5. Explicar sílabo
con IA" as P5
rectangle "P6. Crear plan
de acción" as P6
rectangle "P7. Compartir resumen" as P7
rectangle "P8. Registrar analítica
y auditoría" as P8
rectangle "P9. Mantener catálogo
y sílabos" as P9

collections "D1 users
student_profiles
consent_records" as D1
collections "D2 vocational_reports" as D2
database "D3 careers
courses
career_courses
syllabi" as D3
collections "D4 career_comparisons
syllabus_explanations" as D4
collections "D5 plans_of_action
shared_links" as D5
collections "D6 event_logs
audit_logs" as D6
folder "D7 object storage
PDFs/reportes" as D7
cloud "E1 Chatly AI" as E1
cloud "E2 Test Vocacional UTP
Futuro / carga manual MVP" as E2

Student --> P1 : datos básicos / guest
P1 --> D1 : perfil + consentimiento
Student --> P2 : formulario o archivo
E2 ..> P2 : adapter posterior
P2 --> D2 : scores_json / top_careers_json
P2 --> D7 : PDF/archivo original
Student --> P3 : selecciona 2-3 carreras
P3 --> D3 : consulta malla y cursos
D3 --> P3 : catálogo publicable
P3 --> Student : opciones y ciclos
Student --> P4 : solicita duelo de carreras
P4 --> D1 : perfil
P4 --> D2 : scores
P4 --> D3 : cursos/sílabos
P4 --> E1 : contexto mínimo + prompt
E1 --> P4 : JSON estructurado validable
P4 --> D4 : comparison_json
P4 --> Student : resumen, barras, fitNarrative
Student --> P5 : abre curso/sílabo
P5 --> D3 : parsed_json / syllabus
P5 --> E1 : prompt explicación
E1 --> P5 : explanation_json
P5 --> D4 : explicación cacheable
P5 --> Student : explicación clara
Student --> P6 : elige meta y tareas
P6 --> D5 : tasks_json / status
P6 --> Student : plan accionable
Student --> P7 : genera enlace familiar
P7 --> D5 : shared_link
Family --> P7 : lee resumen compartido
Admin --> P9 : alta/edición carreras
cursos/sílabos
P9 --> D3 : datos maestros versionados
P1 --> P8
P2 --> P8
P4 --> P8
P5 --> P8
P6 --> P8
P7 --> P8
P9 --> P8
P8 --> D6 : eventos/auditoría

note right of E1
No enviar PDF completo si no es necesario.
Usar minimización de contexto y validación JSON.
end note
@enduml
