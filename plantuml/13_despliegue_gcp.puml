@startuml
skinparam componentStyle rectangle
skinparam linetype ortho

title DIAGRAMA DE ARQUITECTURA FÍSICA: GCP + MOBILE + POSTGRES + SPECIALIZED PSYCHOLOGY IA + Caching

' --- CAPA DE PRESENTACIÓN ---
package "CAPA DE PRESENTACIÓN\n(APLICACIÓN MÓVIL)" as CapaPresentacion {
    component "APLICACIÓN MÓVIL\nRESPONSIVA\n(Flutter/React Native)" as MobileApp
}

cloud "internet" as Internet

' --- CAPA DE BACKEND ---
package "CAPA DE BACKEND" as CapaBackend {
    
    package "SUBRED PÚBLICA" as SubredPublica {
        component "GCP Load\nBalancer" as LoadBalancerPub
    }
    
    package "SUBRED PRIVADA VPC" as SubredPrivada {
        component "GCP Load\nBalancer" as LoadBalancerPriv
        
        package "Google Kubernetes Engine (GKE) Cluster" as GKECluster {
            frame "GKE Nodes" as GKENodes {
                component "Microservicios\nBackend\n(Node.js/Go)" as MicroservicesNode
                component "Microservicios\nBackend\n(Node.js/Go)" as MicroservicesGo
            }
        }
        
        package "Data Layer / Backend Layer" as DataLayer {
            database "Cloud SQL for\nPostgreSQL\n(Instancia Gestionada)" as CloudSQL
            database "GCP CLOUD MEMORYSTORE\nFOR REDIS\n(Instancia Gestionada)" as Redis
        }
    }
}

' --- API / IA EXTENSIONES ---
package "API" as CapaAPI {
    package "PSYCHOLOGY IA\nGATEWAY" as IAGateway {
        component "UTP VOCATIONAL IA API\n(Nich Especializado:\nPerfiles Académicos)" as UTP_IA
        component "PSYCHOTHERAPEUTIC\nCHAT API\n(Internal Specialized\nReasoning: Chat &\nEmpathy)" as Psychotherapeutic_IA
    }
    
    component "Chatly -\nOpenAI GPT-4\n(Externa)" as Chatly
}

' --- RELACIONES Y FLUJOS DE DATOS ---

' Conexión desde el móvil por internet
MobileApp -right-> Internet
Internet -right-> LoadBalancerPriv

' API Call externa/pública al Load Balancer Público
note top of LoadBalancerPub : API CALL (HTTPS)
LoadBalancerPub -down-> GKECluster

' Flujo desde el Load Balancer Privado a los Nodos de GKE
LoadBalancerPriv -right-> GKENodes

' Conexión a los microservicios específicos
GKENodes -right-> MicroservicesNode
GKENodes -right-> MicroservicesGo

' Interacciones con la Base de Datos y Caché
MicroservicesNode --> CloudSQL
MicroservicesGo --> CloudSQL
MicroservicesNode --> Redis : Caching
MicroservicesGo --> Redis : Caching
CloudSQL <-> Redis

' Conexiones de salida hacia las APIs de IA (Cognitive Analysis Core)
MicroservicesNode -right-> IAGateway : "API CALL\n(HTTPS)"
MicroservicesGo -right-> IAGateway : "API CALL\n(HTTPS)"

UTP_IA -[hidden]down-> Psychotherapeutic_IA

' Conexión de Fallback externa (General Non-Clinical Support)
MicroservicesGo --> Chatly : "General Non-Clinical\nSupport (Fallback)"

@enduml