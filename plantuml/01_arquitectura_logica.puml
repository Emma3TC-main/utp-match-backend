@startuml 01_arquitectura_logica_utp_match
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam handwritten false
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam ArrowColor #444444
skinparam classAttributeIconSize 0
skinparam roundcorner 12
skinparam nodesep 45
skinparam ranksep 40
title UTP Match / SyllabusX - Arquitectura lógica MVP + evolución

actor "Estudiante\n4.º/5.º secundaria" as Student
actor "Familia / Tutor" as Family
actor "Promotor / Orientador UTP" as Advisor
actor "Administrador\nde catálogo" as Admin

package "Capa de experiencia" as UX {
  component "Web App Responsive\nNext.js / React / Tailwind" as WebApp
  component "PWA Mobile Simplified\nReact responsive" as PWA
  component "Panel Admin mínimo\nCatálogo y sílabos" as AdminUI
}

package "Capa de acceso y seguridad" as Access {
  component "API Gateway / Edge Router\nHTTPS + CORS + Rate Limit" as Gateway
  component "Auth & Roles\nSupabase Auth / GCP IAM\nJWT + RLS" as Auth
  component "Consentimiento y privacidad\nversionado + auditoría" as Consent
}

package "Backend modular monolith\nNode.js + TypeScript para MVP" as Backend {
  component "User/Profile Service" as ProfileSvc
  component "Career Catalog Service" as CatalogSvc
  component "Vocational Report Adapter\nmanual / PDF / JSON" as ReportSvc
  component "Comparison Engine\nperfil + carrera + sílabo" as CompareSvc
  component "Syllabus Explainer Service" as ExplainSvc
  component "Action Plan Service" as PlanSvc
  component "Analytics Event Service" as EventSvc
  component "AI Orchestration Service\nprompting + JSON validation" as AISvc
}

package "Datos y conocimiento" as Data {
  database "PostgreSQL / Supabase\nRelacional + JSONB" as Postgres
  folder "Object Storage\nPDFs de sílabos / reportes" as Storage
  collections "Redis / Cache opcional\nexplicaciones frecuentes" as Redis
}

cloud "Chatly AI\nProveedor IA generativa" as Chatly
cloud "Test Vocacional UTP\nAdapter futuro / carga manual MVP" as VocationalUTP
cloud "CRM / Admisión UTP\nIntegración futura" as CRM
cloud "Observabilidad\nLogs + métricas + trazas" as Obs

Student --> WebApp : explora carreras\ncompara y guarda plan
Student --> PWA : uso móvil
Family --> WebApp : revisa resumen compartido
Advisor --> WebApp : acompaña decisión
Admin --> AdminUI : mantiene catálogo

WebApp --> Gateway : REST /v1 + JSON
PWA --> Gateway : REST /v1 + JSON
AdminUI --> Gateway : REST /v1/admin
Gateway --> Auth : valida JWT / guest
Gateway --> Consent : verifica consentimiento
Gateway --> Backend : enruta dominio

ProfileSvc --> Postgres
CatalogSvc --> Postgres
ReportSvc --> Postgres
ReportSvc --> Storage : guarda PDF/archivo
ReportSvc ..> VocationalUTP : adapter posterior
CompareSvc --> Postgres : mallas, cursos, perfil
CompareSvc --> AISvc : narrativa y preguntas
ExplainSvc --> Postgres : sílabo parseado
ExplainSvc --> AISvc : explicación estructurada
PlanSvc --> Postgres
EventSvc --> Postgres : eventos de producto
AISvc --> Chatly : prompt + contexto mínimo
AISvc --> Redis : cache por syllabus_hash/prompt_version
Backend --> Obs : logs/traces/metrics
Gateway --> Obs
CRM ..> EventSvc : lead cualificado\nroadmap 6-12 meses

note right of Backend
MVP decidido:
- React / Next.js en frontend
- Node.js + TypeScript como backend modular
- REST-first
- PostgreSQL/Supabase
- Chatly AI para recomendación/explicación
end note

note bottom of Data
JSONB se usa para:
- scores_json del reporte vocacional
- parsed_json del sílabo
- explanation_json y comparison_json
- event_props_json / metadata_json
end note
@enduml