# ==========================================================
# UTP Match Backend - Variables de entorno de ejemplo
# Copiar este archivo como .env y completar valores reales.
# NO subir .env al repositorio.
# ==========================================================

@'
PORT=3000
NODE_ENV=development
API_PREFIX=/v1

SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_SUPABASE_PUBLISHABLE_KEY

DATABASE_ENABLED=true
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:PUERTO/postgres

JWT_SECRET=GENERAR_UN_STRING_LARGO_SEGURO

CHATLY_ENABLED=false
CHATLY_API_KEY=PENDIENTE_CONFIGURAR
CHATLY_BASE_URL=https://api.chatly.ai
CHATLY_MODEL=deepseek

FRONTEND_URL=http://localhost:5173
MOBILE_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8081
'@ | Set-Content -Path ".env.example" -Encoding UTF8
